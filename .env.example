# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Discord webhook URL — create one in your server's channel settings
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Minimum relevance score (1–10) an article must receive before being posted.
# Lower = more permissive, higher = stricter. Defaults to 6 if not set.
RELEVANCE_THRESHOLD=6

# Max number of new articles to analyse per feed per cycle.
# Prevents large backlogs from burning API tokens. Defaults to 5.
MAX_NEW_PER_FEED=5

# Claude model to use for article analysis.
# Haiku is ~20x cheaper than Sonnet and works well for scoring/filtering.
# Options: claude-haiku-4-5-20251001 (cheap), claude-sonnet-4-20250514 (smarter)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
