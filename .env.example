# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Discord webhook URL — create one in your server's channel settings
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Minimum relevance score (1–10) an article must receive before being posted.
# Lower = more permissive, higher = stricter. Defaults to 6 if not set.
RELEVANCE_THRESHOLD=6
